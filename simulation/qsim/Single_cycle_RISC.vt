		&& ((RegWriteOut_expected_prev !== last_RegWriteOut_exp) ||
			on_first_change[12])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port RegWriteOut :: @time = %t",  $realtime);
		$display ("     Expected value = %b", RegWriteOut_expected_prev);
		$display ("     Real value = %b", RegWriteOut_prev);
		nummismatches = nummismatches + 1;
		on_first_change[12] = 1'b0;
		last_RegWriteOut_exp = RegWriteOut_expected_prev;
	end
	if (
		( Zero_expected_prev !== 1'bx ) && ( Zero_prev !== Zero_expected_prev )
		&& ((Zero_expected_prev !== last_Zero_exp) ||
			on_first_change[13])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port Zero :: @time = %t",  $realtime);
		$display ("     Expected value = %b", Zero_expected_prev);
		$display ("     Real value = %b", Zero_prev);
		nummismatches = nummismatches + 1;
		on_first_change[13] = 1'b0;
		last_Zero_exp = Zero_expected_prev;
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1200000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module Datapath_vlg_vec_tst();
// constants                                           
// general purpose registers
reg Gclock;
reg Greset;
// wires                                               
wire ALUop1;
wire ALUop2;
wire ALUSRC;
wire BranchOut;
wire [31:0] InstructionOut;
wire JumpOut;
wire MemoryRead;
wire MemoryToRegister;
wire MemWriteOut;
wire [7:0] MuxOut;
wire RegisterDst;
wire RegWriteOut;
wire Zero;

wire sampler;                             

// assign statements (if any)                          
Datapath i1 (
// port map - connection between master ports and signals/registers   
	.ALUop1(ALUop1),
	.ALUop2(ALUop2),
	.ALUSRC(ALUSRC),
	.BranchOut(BranchOut),
	.Gclock(Gclock),
	.Greset(Greset),
	.InstructionOut(InstructionOut),
	.JumpOut(JumpOut),
	.MemoryRead(MemoryRead),
	.MemoryToRegister(MemoryToRegister),
	.MemWriteOut(MemWriteOut),
	.MuxOut(MuxOut),
	.RegisterDst(RegisterDst),
	.RegWriteOut(RegWriteOut),
	.Zero(Zero)
);

// Gclock
always
begin
	Gclock = 1'b0;
	Gclock = #40000 1'b1;
	#40000;
end 

// Greset
initial
begin
	Greset = 1'b1;
	Greset = #1120000 1'b0;
end 

Datapath_vlg_sample_tst tb_sample (
	.Gclock(Gclock),
	.Greset(Greset),
	.sampler_tx(sampler)
);

Datapath_vlg_check_tst tb_out(
	.ALUop1(ALUop1),
	.ALUop2(ALUop2),
	.ALUSRC(ALUSRC),
	.BranchOut(BranchOut),
	.InstructionOut(InstructionOut),
	.JumpOut(JumpOut),
	.MemoryRead(MemoryRead),
	.MemoryToRegister(MemoryToRegister),
	.MemWriteOut(MemWriteOut),
	.MuxOut(MuxOut),
	.RegisterDst(RegisterDst),
	.RegWriteOut(RegWriteOut),
	.Zero(Zero),
	.sampler_rx(sampler)
);
endmodule

